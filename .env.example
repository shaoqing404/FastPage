# Core runtime
APP_ENV=dev
API_HOST=127.0.0.1
API_PORT=22223

# Local data root. In default SQLite mode the database will live at
# ${DATA_DIR}/app.db unless SQLITE_PATH is set.
DATA_DIR=./data

# Database runtime selection
# - Default and recommended for local development: DATABASE_MODE=sqlite
# - Use DATABASE_MODE=mysql for a remote or shared MySQL database
# - Advanced users can set DATABASE_URL directly; if DATABASE_URL is set, it
#   overrides DATABASE_MODE, SQLITE_PATH, and all MYSQL_* parts.
DATABASE_MODE=sqlite
DATABASE_URL=

# Optional SQLite override. Leave empty unless you want the SQLite file in a
# custom location. This is a filesystem path, not a sqlite:/// URL.
SQLITE_PATH=

# MySQL parts used only when DATABASE_MODE=mysql and DATABASE_URL is empty.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=pageindex
MYSQL_USER=pageindex
MYSQL_PASSWORD=

SECRET_KEY=change-me-local-dev-secret-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-local-admin-password

STORAGE_BACKEND=local
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_PREFIX_PATH=
MINIO_SECURE=false

TASK_QUEUE_BACKEND=local
REDIS_URL=
QUEUE_NAME_PARSE=pageindex:parse
QUEUE_NAME_CHAT=pageindex:chat
QUEUE_NAME_COMPLIANCE=pageindex:compliance
WORKER_PROCESS_COUNT=1
WORKER_MAX_TASKS_PER_CHILD=50
WORKER_MAX_RSS_MB=1024
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_TTL_SECONDS=45
WORKER_RECONNECT_DELAY_MS=2000
WORKER_REGISTRY_PREFIX=pageindex:workers
REDIS_SOCKET_TIMEOUT_SECONDS=30
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

CHAT_RUN_POLL_INTERVAL_MS=200
# Max synchronous wait for /api/v1/chat/skills/:id/run and similar blocking chat run APIs.
# Long-running runs may still continue in the worker after this timeout is reached.
CHAT_RUN_REQUEST_TIMEOUT_SECONDS=600
CHAT_RUN_LEASE_TIMEOUT_SECONDS=90
CHAT_RUN_QUEUE_RETRY_DELAY_MS=500
COMPLIANCE_RUN_POLL_INTERVAL_MS=500
COMPLIANCE_RUN_REQUEST_TIMEOUT_SECONDS=600
COMPLIANCE_RUN_LEASE_TIMEOUT_SECONDS=120
COMPLIANCE_RUN_QUEUE_RETRY_DELAY_MS=500
RETRIEVAL_MAX_CONCURRENCY=8
RUN_MAX_MANUALS=20
RUN_STEP_MAX_RETRIES=2
RUN_STEP_RETRY_BASE_MS=500
# System-level rerank fallback.
# Used when a skill/compliance run enables rerank, but the selected provider
# does not expose any rerank-capable model.
# Resolution order is:
# 1. skill/provider rerank model
# 2. SYSTEM_RERANK_* fallback below
# 3. no rerank
# Set SYSTEM_RERANK_ENABLED=true only when the base URL / key / model are all valid.
SYSTEM_RERANK_ENABLED=false
# Base URL for the dedicated rerank provider, for example a DashScope /
# OpenAI-compatible rerank endpoint.
SYSTEM_RERANK_BASE_URL=
# API key for the dedicated rerank provider.
SYSTEM_RERANK_API_KEY=
# Default rerank model name used by the system fallback.
SYSTEM_RERANK_MODEL=
# Provider type label used for diagnostics and execution context.
SYSTEM_RERANK_PROVIDER_TYPE=openai_compatible

# System-level embedding fallback.
# Reserved for future routing/build flows and stays disabled by default.
# Resolution order is:
# 1. provider-native embedding model
# 2. SYSTEM_EMBEDDING_* fallback below
# 3. no embedding
SYSTEM_EMBEDDING_ENABLED=false
# Base URL for the dedicated embedding provider, for example an OpenAI-compatible embeddings endpoint.
SYSTEM_EMBEDDING_BASE_URL=
# API key for the dedicated embedding provider.
SYSTEM_EMBEDDING_API_KEY=
# Default embedding model name used by the system fallback.
SYSTEM_EMBEDDING_MODEL=
# Provider type label used for diagnostics and execution context.
SYSTEM_EMBEDDING_PROVIDER_TYPE=openai_compatible

# Routing asset build hooks. Canonical values: disabled, dry_run, enabled.
# Defaults keep optional routing assets out of online retrieval.
# Legacy aliases accepted by code:
# - off/false/no/disabled -> disabled
# - dryrun/dry -> dry_run
# - on/true/persist/materialize/build -> enabled
ROUTING_ROUTE_DOCS_BUILD_MODE=disabled
ROUTING_SYNTHETIC_QUERIES_BUILD_MODE=disabled
ROUTING_EMBEDDINGS_BUILD_MODE=disabled
OBSERVATION_TEXT_MAX_CHARS=12000

MAX_UPLOAD_BYTES=2147483648
PROVIDER_URL_ALLOW_PRIVATE_NETS=true

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_ORIGIN_REGEX=
