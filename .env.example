APP_ENV=dev
API_HOST=127.0.0.1
API_PORT=22223

DATA_DIR=./data
DATABASE_URL=sqlite:///./data/app.db

SECRET_KEY=change-me-to-a-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

STORAGE_BACKEND=local
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pageindex
MINIO_PREFIX_PATH=
MINIO_SECURE=false

TASK_QUEUE_BACKEND=local
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME_PARSE=pageindex:parse
QUEUE_NAME_CHAT=pageindex:chat

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

CHAT_RUN_POLL_INTERVAL_MS=200
CHAT_RUN_REQUEST_TIMEOUT_SECONDS=30
CHAT_RUN_LEASE_TIMEOUT_SECONDS=90
CHAT_RUN_QUEUE_RETRY_DELAY_MS=500

MAX_UPLOAD_BYTES=2147483648
PROVIDER_URL_ALLOW_PRIVATE_NETS=true

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=
