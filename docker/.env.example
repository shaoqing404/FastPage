# ── Application ─────────────────────────────────────────────────────────────
# Runtime mode: dev | test | prod
# In prod mode, insecure SECRET_KEY / ADMIN_PASSWORD defaults will cause
# startup failure.
APP_ENV=dev

ADMIN_USERNAME=admin
ADMIN_PASSWORD=<CHANGE_ME>
SECRET_KEY=<CHANGE_ME_GENERATE_RANDOM_SECRET>

# ── Network ─────────────────────────────────────────────────────────────────
# Default binds to 127.0.0.1 (localhost only).
# Use 0.0.0.0 ONLY behind a reverse proxy (nginx, Caddy, etc.).
API_HOST=127.0.0.1
API_PORT=22223
WORKER_REPLICAS=2
WORKER_NODE_CODE_PREFIX=worker

# ── Data ────────────────────────────────────────────────────────────────────
DATA_DIR=/app/data

# ── LLM Provider ────────────────────────────────────────────────────────────
LLM_BASE_URL=<LLM_PROVIDER_BASE_URL>
LLM_API_KEY=<LLM_API_KEY>

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:3306/pageindex

# ── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=<MINIO_HOST>:9000
MINIO_ACCESS_KEY=<MINIO_ACCESS_KEY>
MINIO_SECRET_KEY=<MINIO_SECRET_KEY>
MINIO_BUCKET=pageindex
MINIO_PREFIX_PATH=
MINIO_SECURE=false

# ── Task Queue ──────────────────────────────────────────────────────────────
TASK_QUEUE_BACKEND=redis
REDIS_URL=redis://:<REDIS_PASSWORD>@<REDIS_HOST>:6379/1
QUEUE_NAME_PARSE=pageindex:parse
QUEUE_NAME_CHAT=pageindex:chat

# ── Upload Limits ───────────────────────────────────────────────────────────
# Maximum upload size in bytes (default 2 GB).
# Must match reverse proxy body-size limit (e.g. nginx client_max_body_size).
MAX_UPLOAD_BYTES=2147483648

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins for browser access.
# In prod, do NOT leave empty — set the explicit origin(s) of your frontend.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOW_ORIGIN_REGEX=
