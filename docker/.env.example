# Demo defaults in this file are only for local demo / test compose usage.
# Production deployments must replace all passwords and generate a strong
# SECRET_KEY separately.

# ── Shared Core ─────────────────────────────────────────────────────────────
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=22223
WORKER_PROCESS_COUNT=1
WORKER_NODE_CODE_PREFIX=worker
WORKER_MAX_TASKS_PER_CHILD=50
WORKER_MAX_RSS_MB=1024
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_TTL_SECONDS=45
WORKER_RECONNECT_DELAY_MS=2000
WORKER_REGISTRY_PREFIX=pageindex:workers
REDIS_SOCKET_TIMEOUT_SECONDS=30
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

ADMIN_USERNAME=admin
ADMIN_PASSWORD=pageindex_service123
SECRET_KEY=pageindex_service123_demo_secret_key_change_me_for_real_deploy

DATA_DIR=/app/data
MAX_UPLOAD_BYTES=2147483648
PROVIDER_URL_ALLOW_PRIVATE_NETS=true
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_ORIGIN_REGEX=

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

CHAT_RUN_POLL_INTERVAL_MS=200
CHAT_RUN_REQUEST_TIMEOUT_SECONDS=30
CHAT_RUN_LEASE_TIMEOUT_SECONDS=90
CHAT_RUN_QUEUE_RETRY_DELAY_MS=500
QUEUE_NAME_PARSE=pageindex:parse
QUEUE_NAME_CHAT=pageindex:chat
QUEUE_NAME_COMPLIANCE=pageindex:compliance
COMPLIANCE_RUN_POLL_INTERVAL_MS=500
COMPLIANCE_RUN_REQUEST_TIMEOUT_SECONDS=30
COMPLIANCE_RUN_LEASE_TIMEOUT_SECONDS=120
COMPLIANCE_RUN_QUEUE_RETRY_DELAY_MS=500
RETRIEVAL_MAX_CONCURRENCY=8
RUN_MAX_MANUALS=20
RUN_STEP_MAX_RETRIES=2
RUN_STEP_RETRY_BASE_MS=500
# System-level rerank fallback for worker/runtime execution.
# Effective order:
# 1. provider-native rerank model
# 2. SYSTEM_RERANK_* fallback below
# 3. no rerank
SYSTEM_RERANK_ENABLED=false
# Dedicated rerank endpoint base URL.
SYSTEM_RERANK_BASE_URL=
# Dedicated rerank endpoint API key.
SYSTEM_RERANK_API_KEY=
# Dedicated rerank model name.
SYSTEM_RERANK_MODEL=
# Provider type label recorded in execution context / diagnostics.
SYSTEM_RERANK_PROVIDER_TYPE=openai_compatible

# System-level embedding provider for node embedding shadow/artifact builds.
# app.core.config reads the SYSTEM_EMBEDDING_* names below; do not use
# shortened SYSTEM_EMB_* aliases in runtime env files.
# Keep disabled until an operator intentionally validates embedding artifact output.
SYSTEM_EMBEDDING_ENABLED=false
# Dedicated embedding endpoint base URL, for example:
# https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
SYSTEM_EMBEDDING_BASE_URL=
# Dedicated embedding endpoint API key.
SYSTEM_EMBEDDING_API_KEY=
# Dedicated embedding model name.
SYSTEM_EMBEDDING_MODEL=
# Provider type label recorded in execution context / diagnostics.
SYSTEM_EMBEDDING_PROVIDER_TYPE=openai_compatible
# Embedding request hardening. Defaults are conservative for DashScope/OpenAI-compatible providers.
SYSTEM_EMBEDDING_BATCH_SIZE=10
SYSTEM_EMBEDDING_TIMEOUT_SECONDS=30
SYSTEM_EMBEDDING_MAX_RETRIES=2
SYSTEM_EMBEDDING_RETRY_BASE_SECONDS=0.25

# Optional node embedding ES shadow serving backend.
# Artifact bundles remain canonical; keep disabled until separately validated.
# To use ES shadow backend, install optional dependency:
#   pip install .[es]   or   uv pip install .[es]
ROUTING_NODE_ES_ENABLED=false
# Legacy compound URL; if set and non-empty it wins over the split fields below.
ROUTING_NODE_ES_URL=
ROUTING_NODE_ES_HOST=127.0.0.1
ROUTING_NODE_ES_PORT=9200
ROUTING_NODE_ES_USER=
ROUTING_NODE_ES_PASSWORD=
ROUTING_NODE_ES_USE_SSL=false
ROUTING_NODE_ES_INDEX_PREFIX=pageindex-node-embeddings

# Routing asset build hooks. Canonical values: disabled, dry_run, enabled.
# Keep disabled until an operator intentionally validates dry-run output.
# Set ROUTING_EMBEDDINGS_BUILD_MODE=enabled only for an intentional embedding artifact run.
ROUTING_ROUTE_DOCS_BUILD_MODE=disabled
ROUTING_SYNTHETIC_QUERIES_BUILD_MODE=disabled
ROUTING_EMBEDDINGS_BUILD_MODE=disabled
OBSERVATION_TEXT_MAX_CHARS=12000

# ── Database Runtime Selection ─────────────────────────────────────────────
# Full profile: DATABASE_MODE=mysql plus MYSQL_* parts below.
# Local profile: docker-compose overrides the app to local SQLite automatically.
# Expert override: if DATABASE_URL is set, it wins over DATABASE_MODE and MYSQL_*.
DATABASE_MODE=mysql
DATABASE_URL=
SQLITE_PATH=

# ── Complete Mode Demo Defaults ────────────────────────────────────────────
# Recommended full mode: MySQL + Redis + MinIO + API + Worker.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=pageindex
MYSQL_USER=pageindex
MYSQL_PASSWORD=pageindex_service123
MYSQL_ROOT_PASSWORD=pageindex_service123

# DB pool reliability defaults. Leave commented to use these code defaults.
# Connection budget: total <= process_count * (pool_size + max_overflow) + scripts/admin.
# For 2 API workers + 10 app workers, defaults cap app DB connections at about 60.
# DB_POOL_PRE_PING=true
# DB_POOL_RECYCLE_SECONDS=1800
# DB_POOL_TIMEOUT_SECONDS=5
# DB_POOL_SIZE=3
# DB_MAX_OVERFLOW=2
# RUN_MIGRATIONS_ON_STARTUP=true

REDIS_PASSWORD=pageindex_service123
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
TASK_QUEUE_BACKEND=redis

STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=pageindex_service123
MINIO_SECRET_KEY=pageindex_service123
MINIO_BUCKET=pageindex
MINIO_PREFIX_PATH=
MINIO_SECURE=false

# ── Local Profile Reference ────────────────────────────────────────────────
# The `local` profile overrides these runtime settings inside docker-compose:
# DATABASE_MODE=sqlite
# DATA_DIR=/app/data
# STORAGE_BACKEND=local
# TASK_QUEUE_BACKEND=local
# REDIS_URL=
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=
# MINIO_PREFIX_PATH=
# (REDIS_HOST / REDIS_PORT / etc. are unused when TASK_QUEUE_BACKEND=local)
