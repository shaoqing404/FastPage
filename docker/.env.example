# Demo defaults in this file are only for local demo / test compose usage.
# Production deployments must replace all passwords and generate a strong
# SECRET_KEY separately.

# ── Shared Core ─────────────────────────────────────────────────────────────
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=22223
WORKER_REPLICAS=1
WORKER_PROCESS_COUNT=1
WORKER_NODE_CODE_PREFIX=worker
WORKER_MAX_TASKS_PER_CHILD=50
WORKER_MAX_RSS_MB=1024
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_TTL_SECONDS=45
WORKER_RECONNECT_DELAY_MS=2000
WORKER_REGISTRY_PREFIX=pageindex:workers
REDIS_SOCKET_TIMEOUT_SECONDS=30
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=5
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

ADMIN_USERNAME=admin
ADMIN_PASSWORD=pageindex_service123
SECRET_KEY=pageindex_service123_demo_secret_key_change_me_for_real_deploy

DATA_DIR=/app/data
MAX_UPLOAD_BYTES=2147483648
PROVIDER_URL_ALLOW_PRIVATE_NETS=true
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_ORIGIN_REGEX=

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

CHAT_RUN_POLL_INTERVAL_MS=200
CHAT_RUN_REQUEST_TIMEOUT_SECONDS=30
CHAT_RUN_LEASE_TIMEOUT_SECONDS=90
CHAT_RUN_QUEUE_RETRY_DELAY_MS=500
QUEUE_NAME_PARSE=pageindex:parse
QUEUE_NAME_CHAT=pageindex:chat
QUEUE_NAME_COMPLIANCE=pageindex:compliance
COMPLIANCE_RUN_POLL_INTERVAL_MS=500
COMPLIANCE_RUN_REQUEST_TIMEOUT_SECONDS=30
COMPLIANCE_RUN_LEASE_TIMEOUT_SECONDS=120
COMPLIANCE_RUN_QUEUE_RETRY_DELAY_MS=500
RETRIEVAL_MAX_CONCURRENCY=8
RUN_MAX_MANUALS=20
RUN_STEP_MAX_RETRIES=2
RUN_STEP_RETRY_BASE_MS=500
# System-level rerank fallback for worker/runtime execution.
# Effective order:
# 1. provider-native rerank model
# 2. SYSTEM_RERANK_* fallback below
# 3. no rerank
SYSTEM_RERANK_ENABLED=false
# Dedicated rerank endpoint base URL.
SYSTEM_RERANK_BASE_URL=
# Dedicated rerank endpoint API key.
SYSTEM_RERANK_API_KEY=
# Dedicated rerank model name.
SYSTEM_RERANK_MODEL=
# Provider type label recorded in execution context / diagnostics.
SYSTEM_RERANK_PROVIDER_TYPE=openai_compatible
OBSERVATION_TEXT_MAX_CHARS=12000

# ── Database Runtime Selection ─────────────────────────────────────────────
# Full profile: DATABASE_MODE=mysql plus MYSQL_* parts below.
# Local profile: docker-compose overrides the app to local SQLite automatically.
# Expert override: if DATABASE_URL is set, it wins over DATABASE_MODE and MYSQL_*.
DATABASE_MODE=mysql
DATABASE_URL=
SQLITE_PATH=

# ── Complete Mode Demo Defaults ────────────────────────────────────────────
# Recommended full mode: MySQL + Redis + MinIO + API + Worker.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=pageindex
MYSQL_USER=pageindex
MYSQL_PASSWORD=pageindex_service123
MYSQL_ROOT_PASSWORD=pageindex_service123

REDIS_PASSWORD=pageindex_service123
REDIS_URL=redis://:pageindex_service123@redis:6379/1
TASK_QUEUE_BACKEND=redis

STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=pageindex_service123
MINIO_SECRET_KEY=pageindex_service123
MINIO_BUCKET=pageindex
MINIO_PREFIX_PATH=
MINIO_SECURE=false

# ── Local Profile Reference ────────────────────────────────────────────────
# The `local` profile overrides these runtime settings inside docker-compose:
# DATABASE_MODE=sqlite
# DATA_DIR=/app/data
# STORAGE_BACKEND=local
# TASK_QUEUE_BACKEND=local
# REDIS_URL=
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=
# MINIO_PREFIX_PATH=
