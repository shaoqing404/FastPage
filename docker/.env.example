# Demo defaults in this file are only for local demo / test compose usage.
# Production deployments must replace all passwords and generate a strong
# SECRET_KEY separately.

# ── Shared Core ─────────────────────────────────────────────────────────────
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=22223

# Worker basic scaling (optional overrides)
# WORKER_PROCESS_COUNT=1
# WORKER_MAX_RSS_MB=1024

ADMIN_USERNAME=admin
ADMIN_PASSWORD=pageindex_service123
SECRET_KEY=pageindex_service123_demo_secret_key_change_me_for_real_deploy

DATA_DIR=/var/lib/pageindex/data
LOG_DIR=/var/log/pageindex
MAX_UPLOAD_BYTES=2147483648
PROVIDER_URL_ALLOW_PRIVATE_NETS=true
ENABLE_LITELLM=false

# Relaxed CORS for development/demo ease of use. Nginx proxies requests, but 
# if you access the API directly, this is needed.
CORS_ALLOW_ORIGINS=*

FRONTEND_PORT=5173

# Docker build defaults. The default Dockerfile is multi-arch and works for
# linux/amd64 and linux/arm64. Set API_DOCKERFILE=docker/Dockerfile.arm64 only
# when you explicitly want the ARM64-tuned file.
API_DOCKERFILE=docker/Dockerfile
UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com/
# Set false if a restricted network cannot reach tiktoken's upstream encoding
# blob during image build. Keep true for offline-ready runtime images.
TIKTOKEN_PREWARM=true

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_api_key_here
# For DashScope OpenAI-compatible endpoint, model name MUST have openai/ prefix (LiteLLM protocol hint)
# Available models: qwen-plus / qwen-turbo / qwen-max / qwen3-235b-a22b etc.
LLM_MODEL=openai/qwen-plus

# ── Database & Task Queue (Core Infrastructure) ───────────────────────────
DATABASE_MODE=mysql
DATABASE_URL=
TASK_QUEUE_BACKEND=redis

# Connection details below match 'full' docker-compose service names.
# Update these if connecting to EXTERNAL services.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=pageindex
MYSQL_USER=pageindex
MYSQL_PASSWORD=pageindex_service123
MYSQL_ROOT_PASSWORD=pageindex_service123

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=pageindex_service123
REDIS_DB=1

# ── Storage & Search (Core Infrastructure) ────────────────────────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=pageindex_service123
MINIO_SECRET_KEY=pageindex_service123
MINIO_BUCKET=pageindex
MINIO_PREFIX_PATH=
MINIO_SECURE=false

# Elasticsearch is used for node embedding shadow/search.
ROUTING_NODE_ES_ENABLED=true
ROUTING_NODE_ES_HOST=elasticsearch
ROUTING_NODE_ES_PORT=9200
ROUTING_NODE_ES_USER=
ROUTING_NODE_ES_PASSWORD=
ROUTING_NODE_ES_INDEX_PREFIX=pageindex-node-embeddings

# ── Embedding (Dense/ES retrieval) ─────────────────────────────────────────
# Required for Fast Search dense retrieval and ES-backed acceleration.
# Recommended: local LM Studio qwen3-embedding-8b (4096-dim, OpenAI-compatible).
# Or use DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1 + text-embedding-v3
SYSTEM_EMBEDDING_ENABLED=true
SYSTEM_EMBEDDING_PROVIDER_TYPE=openai_compatible
SYSTEM_EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
SYSTEM_EMBEDDING_API_KEY=not-needed
SYSTEM_EMBEDDING_MODEL=qwen3-embedding-8b
SYSTEM_EMBEDDING_BATCH_SIZE=10
SYSTEM_EMBEDDING_DIMENSIONS=4096
SYSTEM_EMBEDDING_TIMEOUT_SECONDS=300
ROUTING_EMBEDDINGS_BUILD_MODE=enabled

# ── Rerank (Search result re-ranking) ─────────────────────────────────────
# Uses DashScope native rerank API (gte-rerank-v2 verified).
SYSTEM_RERANK_ENABLED=true
SYSTEM_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
SYSTEM_RERANK_API_KEY=your_rerank_api_key_here
SYSTEM_RERANK_MODEL=gte-rerank-v2
# SYSTEM_RERANK_PROVIDER_TYPE defaults to openai_compatible; auto-detected as dashscope_rerank from URL

# ── Optional / Advanced Settings (Uncomment to override) ───────────────────
# CHAT_RUN_REQUEST_TIMEOUT_SECONDS=30
# COMPLIANCE_RUN_REQUEST_TIMEOUT_SECONDS=30
