APP_ENV=dev

API_HOST=0.0.0.0
API_PORT=22223
WORKER_REPLICAS=1
WORKER_NODE_CODE_PREFIX=worker

SECRET_KEY=change-me-to-a-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

DATA_DIR=/app/data

DATABASE_URL=mysql+pymysql://pageindex:pageindex@mysql:3306/pageindex
REDIS_URL=redis://redis:6379/0
TASK_QUEUE_BACKEND=redis
QUEUE_NAME_PARSE=pageindex:parse
QUEUE_NAME_CHAT=pageindex:chat

STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pageindex
MINIO_PREFIX_PATH=
MINIO_SECURE=false

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

CHAT_RUN_POLL_INTERVAL_MS=200
CHAT_RUN_REQUEST_TIMEOUT_SECONDS=30
CHAT_RUN_LEASE_TIMEOUT_SECONDS=90
CHAT_RUN_QUEUE_RETRY_DELAY_MS=500

MAX_UPLOAD_BYTES=2147483648
PROVIDER_URL_ALLOW_PRIVATE_NETS=true

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=
