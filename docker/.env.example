# Demo defaults in this file are only for local demo / test compose usage.
# Production deployments must replace all passwords and generate a strong
# SECRET_KEY separately.

# ── Shared Core ─────────────────────────────────────────────────────────────
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=22223
WORKER_REPLICAS=1
WORKER_NODE_CODE_PREFIX=worker

ADMIN_USERNAME=admin
ADMIN_PASSWORD=pageindex_service123
SECRET_KEY=pageindex_service123_demo_secret_key_change_me_for_real_deploy

DATA_DIR=/app/data
MAX_UPLOAD_BYTES=2147483648
PROVIDER_URL_ALLOW_PRIVATE_NETS=true
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CORS_ALLOW_ORIGIN_REGEX=

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

CHAT_RUN_POLL_INTERVAL_MS=200
CHAT_RUN_REQUEST_TIMEOUT_SECONDS=30
CHAT_RUN_LEASE_TIMEOUT_SECONDS=90
CHAT_RUN_QUEUE_RETRY_DELAY_MS=500
QUEUE_NAME_PARSE=pageindex:parse
QUEUE_NAME_CHAT=pageindex:chat

# ── Complete Mode Demo Defaults ────────────────────────────────────────────
# Recommended mode: MySQL + Redis + MinIO + API + Worker.
MYSQL_DATABASE=pageindex
MYSQL_USER=pageindex
MYSQL_PASSWORD=pageindex_service123
MYSQL_ROOT_PASSWORD=pageindex_service123
DATABASE_URL=mysql+pymysql://pageindex:pageindex_service123@mysql:3306/pageindex

REDIS_PASSWORD=pageindex_service123
REDIS_URL=redis://:pageindex_service123@redis:6379/1
TASK_QUEUE_BACKEND=redis

STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=pageindex_service123
MINIO_SECRET_KEY=pageindex_service123
MINIO_BUCKET=pageindex
MINIO_PREFIX_PATH=
MINIO_SECURE=false

# ── Minimal Mode Reference ─────────────────────────────────────────────────
# The `local` profile overrides these runtime settings automatically:
# DATABASE_URL=sqlite:////app/data/app.db
# STORAGE_BACKEND=local
# TASK_QUEUE_BACKEND=local
# REDIS_URL=
# MINIO_ENDPOINT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=
# MINIO_PREFIX_PATH=
