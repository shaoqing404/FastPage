# Demo defaults in this file are only for local demo / test compose usage.
# Production deployments must replace all passwords and generate a strong
# SECRET_KEY separately.

# ── Shared Core ─────────────────────────────────────────────────────────────
APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=22223

# Worker basic scaling (optional overrides)
# WORKER_PROCESS_COUNT=1
# WORKER_MAX_RSS_MB=1024

ADMIN_USERNAME=admin
ADMIN_PASSWORD=pageindex_service123
SECRET_KEY=pageindex_service123_demo_secret_key_change_me_for_real_deploy

DATA_DIR=/app/data
MAX_UPLOAD_BYTES=2147483648
PROVIDER_URL_ALLOW_PRIVATE_NETS=true

# Relaxed CORS for development/demo ease of use. Nginx proxies requests, but 
# if you access the API directly, this is needed.
CORS_ALLOW_ORIGINS=*

FRONTEND_PORT=5173

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_api_key_here

# ── Database & Task Queue (Core Infrastructure) ───────────────────────────
DATABASE_MODE=mysql
DATABASE_URL=
TASK_QUEUE_BACKEND=redis

# Connection details below match 'full' docker-compose service names.
# Update these if connecting to EXTERNAL services.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=pageindex
MYSQL_USER=pageindex
MYSQL_PASSWORD=pageindex_service123
MYSQL_ROOT_PASSWORD=pageindex_service123

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=pageindex_service123
REDIS_DB=1

# ── Storage & Search (Core Infrastructure) ────────────────────────────────
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=pageindex_service123
MINIO_SECRET_KEY=pageindex_service123
MINIO_BUCKET=pageindex
MINIO_PREFIX_PATH=
MINIO_SECURE=false

# Elasticsearch is used for node embedding shadow/search.
ROUTING_NODE_ES_ENABLED=true
ROUTING_NODE_ES_HOST=elasticsearch
ROUTING_NODE_ES_PORT=9200
ROUTING_NODE_ES_USER=
ROUTING_NODE_ES_PASSWORD=
ROUTING_NODE_ES_INDEX_PREFIX=pageindex-node-embeddings

# ── Optional / Advanced Settings (Uncomment to override) ───────────────────
# CHAT_RUN_REQUEST_TIMEOUT_SECONDS=30
# COMPLIANCE_RUN_REQUEST_TIMEOUT_SECONDS=30
# SYSTEM_RERANK_ENABLED=false
# SYSTEM_EMBEDDING_ENABLED=false
# ROUTING_EMBEDDINGS_BUILD_MODE=disabled
