# Use a multi-platform base image that supports ARM64 natively
FROM python:3.12-slim

# Set environment variables for Python and uv
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

# Set the working directory
WORKDIR /app

# Install system dependencies (including uv)
# We use the official uv installer for the fastest and most reliable ARM64 setup
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && curl -LsSf https://astral.sh/uv/install.sh | sh

# Add uv to the PATH
ENV PATH="/root/.local/bin/:$PATH"

# Copy dependency files first to leverage Docker layer caching
COPY requirements.txt /app/

# Install dependencies using uv (much faster than pip)
# --system flag installs into the system python, which is fine in a container
RUN uv pip install --system -r requirements.txt

# ── Pre-warm tiktoken encoding files into the image ─────────────────────────
# litellm.token_counter() internally calls tiktoken, which downloads encoding
# files from openaipublic.blob.core.windows.net on first use. We pre-download
# them here so the runtime container never needs outbound internet access.
ENV TIKTOKEN_CACHE_DIR=/root/.tiktoken
RUN python -c "
import tiktoken, sys

encodings = ['cl100k_base', 'o200k_base', 'p50k_base']
for name in encodings:
    try:
        enc = tiktoken.get_encoding(name)
        n = len(enc.encode('hello world tiktoken warmup test 你好'))
        print(f'  OK  {name}  ({n} tokens for smoke-test string)', flush=True)
    except Exception as e:
        print(f'  FAIL {name}: {e}', file=sys.stderr, flush=True)
        sys.exit(1)
print('tiktoken warm-up complete.', flush=True)
"

# Copy the rest of the application code
COPY . /app

# Expose the application port
EXPOSE 22223

# The command expects to be overridden by docker-compose or run arguments
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "22223"]

